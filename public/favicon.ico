<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Favicon ReLoHu</title>
    <style>
        body {
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background: #f8fafc;
        }
        .container {
            text-align: center;
        }
        .logo {
            font-family: 'Georgia', serif;
            font-size: 120px;
            font-weight: 700;
            color: #10b981; /* Menta verde */
            text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
            line-height: 1;
        }
        .subtitle {
            margin-top: 10px;
            font-size: 16px;
            color: #64748b;
            font-family: Arial, sans-serif;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="logo">R</div>
        <div class="subtitle">ReLoHu</div>
    </div>
</body>
</html>
